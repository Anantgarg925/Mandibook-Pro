generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Shop {
  id          String  @id @default(cuid())
  firmName    String
  ownerName   String
  address     String
  city        String
  phone1      String
  phone2      String
  upiId       String
  upiApps     String  // JSON array of strings
  commodity   String
  grades      String  // JSON array of Grade objects
  charges     String  // JSON ShopCharges object
  adminPin    String
  teamNames   String  // JSON array of strings
  createdAt   Float

  trucks       Truck[]
  inquiries    Inquiry[]
  buyers       Buyer[]
  transactions Transaction[]
  members      Member[]
}

model Truck {
  id             String  @id @default(cuid())
  shopId         String
  truckNumber    String
  senderName     String
  senderCode     String
  chlNumber      String
  totalKg        Float
  freightAmount  Float
  gradeInventory String  // JSON array
  isGodown       Boolean @default(false)
  godownDate     Float?
  status         String  @default("ACTIVE")
  date           Float
  createdAt      Float

  shop       Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  inquiries  Inquiry[]
  gradeEntries TruckGradeEntry[]
}

model TruckGradeEntry {
  id         String @id @default(cuid())
  truckId    String
  gradeLabel String
  weightKg   Float
  createdAt  Float

  truck Truck @relation(fields: [truckId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id             String  @id @default(cuid())
  shopId         String
  slipNumber     Int
  truckId        String
  truckNumber    String
  customerName   String
  customerPhone  String
  grade          String
  gradeName      String
  sacks          Int
  weightPerSack  Float
  totalWeight    Float
  ratePerKg      Float
  grossAmount    Float
  apmcAmount     Float
  bardanaAmount  Float
  cartageAmount  Float
  netAmount      Float
  paymentMode    String
  upiRef         String  @default("")
  status         String  @default("PENDING")
  date           Float
  createdAt      Float

  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  truck Truck @relation(fields: [truckId], references: [id], onDelete: Cascade)
}

model Buyer {
  id                   String  @id @default(cuid())
  shopId               String
  code                 String
  name                 String
  phone                String
  outstandingBalance   Float   @default(0)
  openingBalance       Float   @default(0)
  openingBalanceType   String  @default("DR")
  openingBalanceDate   Float?
  openingBalanceSet    Boolean @default(false)
  notes                String  @default("")
  lastTransactionDate  Float
  lastPaymentAmount    Float?
  lastPaymentDate      Float?
  createdAt            Float

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([shopId, code])
}

model Member {
  id        String  @id @default(cuid())
  shopId    String
  name      String
  phone     String
  pin       String
  role      String  @default("MEMBER") // 'ADMIN' or 'MEMBER'
  createdAt Float

  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, phone])
}

model Transaction {
  id            String  @id @default(cuid())
  shopId        String
  buyerCode     String
  type          String  // 'SALE' | 'PAYMENT' | 'OPENING'
  amount        Float
  date          Float
  paymentMethod String?
  upiRef        String?
  note          String?
  slipNumber    Int?
  createdAt     Float

  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  buyer Buyer @relation(fields: [buyerCode, shopId], references: [code, shopId], onDelete: Cascade)
}
