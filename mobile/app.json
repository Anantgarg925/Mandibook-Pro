{
  "expo": {
    "name": "MandiBook Pro",
    "slug": "mandibook-pro",
    "scheme": "mandibook",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.mandibook.pro",
      "supportsTablet": false
    },
    "android": {
      "package": "com.mandibook.pro",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#00450d"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
